#!/usr/bin/env bash
# argus-discover — Scan for ARGUS nodes and generate Prometheus targets.
#
# Usage:
#   argus-discover --subnet 10.0.0.0/24
#   argus-discover --subnet 10.0.0.0/24 --port 9100 --output /etc/prometheus/argus-targets.json
#   argus-discover --subnet 10.0.0.0/24 --label cluster=gpu-rack-1
#   argus-discover --subnet 192.168.5.0/24 --timeout 2 --dry-run
#   argus-discover --hostfile hosts.txt --port 9100
#   argus-discover --hosts node1,node2,fd00::1,[fd00::2]:9200
#   argus-discover --subnet fd00::/120 --port 9100
#
# Source modes:
#   --subnet CIDR          IPv4 or small IPv6 prefix (/120+, max 256 hosts)
#   --hostfile FILE        One hostname/IP per line
#   --hosts H1,H2,...      Comma-separated hostnames/IPs
#
# The script probes each host on the ARGUS metrics port (default 9100) looking
# for a valid /health endpoint. Discovered nodes are written as a Prometheus
# file_sd_configs JSON file that Prometheus hot-reloads automatically.
#
# Requirements: bash 4+, curl (or nc as fallback)

set -euo pipefail

PORT=9100
OUTPUT=""
TIMEOUT=2
DRY_RUN=false
START_STACK=false
LABELS=()
SUBNET=""
HOSTFILE=""
HOSTS=""

# Format host for curl — wrap IPv6 addresses in brackets
curl_host() {
    local h="$1"
    if [[ "$h" == *:* && "$h" != \[* ]]; then
        echo "[$h]"
    else
        echo "$h"
    fi
}

# Format a host:port as a Prometheus target — brackets for IPv6
format_target() {
    local h="$1" p="$2"
    if [[ "$h" == *:* ]]; then
        echo "[${h}]:${p}"
    else
        echo "${h}:${p}"
    fi
}

usage() {
    cat <<EOF
Usage: argus-discover [SOURCE] [OPTIONS]

Source (at least one required):
  --subnet CIDR         IPv4 subnet (e.g. 10.0.0.0/24) or small IPv6 prefix
                        (max /120 = 256 hosts). For larger IPv6 ranges use --hostfile.
  --hostfile FILE       File with one hostname or IP per line
  --hosts H1,H2,...     Comma-separated list of hostnames or IPs

Options:
  --port PORT           ARGUS metrics port (default: 9100)
  --output FILE         Write targets JSON here (default: stdout)
  --label KEY=VALUE     Add label to all discovered targets (repeatable)
  --timeout SECS        Connection timeout per host (default: 2)
  --dry-run             Print discovered hosts but don't write file
  --start               Discover nodes then start the Grafana + Prometheus stack
  -h, --help            Show this help

Examples:
  argus-discover --subnet 10.0.0.0/24
  argus-discover --hostfile /etc/argus/hosts.txt --port 9100
  argus-discover --hosts 10.0.0.1,10.0.0.2,fd00::1 --label env=prod
  argus-discover --subnet fd00:abcd::/120 --output targets.json
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --subnet)   SUBNET="$2"; shift 2 ;;
        --hostfile) HOSTFILE="$2"; shift 2 ;;
        --hosts)    HOSTS="$2"; shift 2 ;;
        --port)     PORT="$2"; shift 2 ;;
        --output)   OUTPUT="$2"; shift 2 ;;
        --label)    LABELS+=("$2"); shift 2 ;;
        --timeout)  TIMEOUT="$2"; shift 2 ;;
        --dry-run)  DRY_RUN=true; shift ;;
        --start)    START_STACK=true; shift ;;
        -h|--help)  usage ;;
        *)          echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

if [[ -z "$SUBNET" && -z "$HOSTFILE" && -z "$HOSTS" ]]; then
    echo "Error: at least one of --subnet, --hostfile, or --hosts is required" >&2
    usage
fi

# ── IPv4 CIDR expansion ──────────────────────────────────────────────

cidr_to_ips() {
    local cidr="$1"
    local base="${cidr%/*}"
    local mask="${cidr#*/}"

    IFS='.' read -r a b c d <<< "$base"
    local ip_num=$(( (a << 24) + (b << 16) + (c << 8) + d ))
    local host_bits=$(( 32 - mask ))
    local num_hosts=$(( 1 << host_bits ))

    local network=$(( ip_num & ( (0xFFFFFFFF << host_bits) & 0xFFFFFFFF ) ))

    for (( i = 1; i < num_hosts - 1; i++ )); do
        local addr=$(( network + i ))
        printf "%d.%d.%d.%d\n" \
            $(( (addr >> 24) & 255 )) \
            $(( (addr >> 16) & 255 )) \
            $(( (addr >> 8) & 255 )) \
            $(( addr & 255 ))
    done
}

# ── IPv6 small-prefix expansion ──────────────────────────────────────
# Only supports /120 or smaller (256 hosts max). Uses python3 for
# 128-bit arithmetic since bash can't handle it.

ipv6_prefix_to_ips() {
    local prefix="$1"
    local mask="${prefix#*/}"

    if (( mask < 120 )); then
        echo "Error: IPv6 prefix /${mask} is too large to enumerate (max /120 = 256 hosts)." >&2
        echo "Use --hostfile with a list of known hosts instead." >&2
        exit 1
    fi

    if ! command -v python3 &>/dev/null; then
        echo "Error: python3 is required for IPv6 prefix expansion" >&2
        exit 1
    fi

    python3 -c "
import ipaddress, sys
net = ipaddress.ip_network('${prefix}', strict=False)
for host in net.hosts():
    print(str(host))
"
}

# ── Collect all candidate IPs/hostnames ──────────────────────────────

CANDIDATES=()

if [[ -n "$SUBNET" ]]; then
    if [[ "$SUBNET" == *:* ]]; then
        echo "Expanding IPv6 prefix ${SUBNET}..." >&2
        mapfile -t v6_hosts < <(ipv6_prefix_to_ips "$SUBNET")
        CANDIDATES+=("${v6_hosts[@]}")
    else
        mapfile -t v4_hosts < <(cidr_to_ips "$SUBNET")
        CANDIDATES+=("${v4_hosts[@]}")
    fi
fi

if [[ -n "$HOSTFILE" ]]; then
    if [[ ! -f "$HOSTFILE" ]]; then
        echo "Error: hostfile not found: ${HOSTFILE}" >&2
        exit 1
    fi
    while IFS= read -r line; do
        line="${line%%#*}"        # strip comments
        line="${line// /}"        # strip whitespace
        [[ -z "$line" ]] && continue
        CANDIDATES+=("$line")
    done < "$HOSTFILE"
fi

if [[ -n "$HOSTS" ]]; then
    IFS=',' read -ra host_list <<< "$HOSTS"
    for h in "${host_list[@]}"; do
        h="${h// /}"
        [[ -z "$h" ]] && continue
        CANDIDATES+=("$h")
    done
fi

TOTAL=${#CANDIDATES[@]}
if [[ $TOTAL -eq 0 ]]; then
    echo "No hosts to scan." >&2
    exit 0
fi

echo "Scanning ${TOTAL} host(s) on port ${PORT}..." >&2

# ── Probe hosts ──────────────────────────────────────────────────────

probe_host() {
    local host="$1"
    local curl_target
    curl_target="$(curl_host "$host")"
    if curl -sf --connect-timeout "$TIMEOUT" --max-time "$((TIMEOUT + 1))" \
        "http://${curl_target}:${PORT}/health" >/dev/null 2>&1; then
        echo "$host"
    fi
}

RESULT_FILE=$(mktemp)
trap 'rm -f "$RESULT_FILE"' EXIT

ACTIVE=0
MAX_PARALLEL=128

for host in "${CANDIDATES[@]}"; do
    ( probe_host "$host" >> "$RESULT_FILE" ) &
    ACTIVE=$((ACTIVE + 1))
    if (( ACTIVE >= MAX_PARALLEL )); then
        wait -n 2>/dev/null || wait
        ACTIVE=$((ACTIVE - 1))
    fi
done
wait

mapfile -t DISCOVERED < "$RESULT_FILE"

echo "Found ${#DISCOVERED[@]} ARGUS node(s) out of ${TOTAL} scanned." >&2

if [[ ${#DISCOVERED[@]} -eq 0 ]]; then
    echo "No nodes found." >&2
    exit 0
fi

if $DRY_RUN; then
    for host in "${DISCOVERED[@]}"; do
        format_target "$host" "$PORT"
    done
    exit 0
fi

# ── Build targets JSON (Prometheus file_sd_configs format) ───────────

build_json() {
    local targets=""
    for host in "${DISCOVERED[@]}"; do
        [[ -n "$targets" ]] && targets+=","
        targets+="\"$(format_target "$host" "$PORT")\""
    done

    local labels_json="\"job\":\"argus\""
    for lbl in "${LABELS[@]+"${LABELS[@]}"}"; do
        local key="${lbl%%=*}"
        local val="${lbl#*=}"
        labels_json+=",\"${key}\":\"${val}\""
    done

    cat <<ENDJSON
[
  {
    "targets": [${targets}],
    "labels": {${labels_json}}
  }
]
ENDJSON
}

JSON=$(build_json)

if $START_STACK; then
    for candidate in \
        "$PWD/deploy/observability" \
        "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd)/deploy/observability" \
    ; do
        if [[ -f "$candidate/docker-compose.yml" ]]; then
            STACK_DIR="$candidate"
            break
        fi
    done
    if [[ -z "${STACK_DIR:-}" ]]; then
        echo "Error: cannot find deploy/observability/docker-compose.yml." >&2
        echo "Run this from the ARGUS repo root, or use --output and start the stack manually." >&2
        exit 1
    fi
    TARGETS_FILE="${OUTPUT:-$STACK_DIR/argus-targets.json}"
    mkdir -p "$(dirname "$TARGETS_FILE")"
    echo "$JSON" > "$TARGETS_FILE"
    echo "Wrote ${TARGETS_FILE}" >&2
    echo "Starting observability stack..." >&2
    exec "$STACK_DIR/scripts/start-observability.sh"
elif [[ -n "$OUTPUT" ]]; then
    mkdir -p "$(dirname "$OUTPUT")"
    echo "$JSON" > "$OUTPUT"
    echo "Wrote ${OUTPUT}" >&2
else
    echo "$JSON"
fi
