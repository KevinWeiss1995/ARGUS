          "expr": "(argus_ib_symbol_errors_delta{instance=\"$node\", device=~\"$device\", port=~\"$port\"} + argus_ib_link_error_recovery_delta{instance=\"$node\", device=~\"$device\", port=~\"$port\"} + argus_ib_port_rcv_errors_delta{instance=\"$node\", device=~\"$device\", port=~\"$port\"} + argus_ib_port_xmit_discards_delta{instance=\"$node\", device=~\"$device\", port=~\"$port\"} + argus_ib_rxe_duplicate_request_delta{instance=\"$node\", device=~\"$device\", port=~\"$port\"} + argus_ib_rxe_seq_error_delta{instance=\"$node\", device=~\"$device\", port=~\"$port\"} + argus_ib_rxe_retry_exceeded_delta{instance=\"$node\", device=~\"$device\", port=~\"$port\"} + argus_ib_rxe_send_error_delta{instance=\"$node\", device=~\"$device\", port=~\"$port\"})",
