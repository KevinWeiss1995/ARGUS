  "panels": [
    {
      "id": 100, "type": "text", "title": "",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "### InfiniBand Link Drill-Down\nSelect a **Node**, **Device**, and **Port** above. If the dropdowns are empty, no IB hardware was discovered on the selected node. This dashboard requires physical InfiniBand or Soft-RoCE to populate."
      }
    },
    {
      "id": 1, "type": "stat", "title": "Link Status",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_ib_link_downed_delta{instance=\"$node\", device=~\"$device\", port=~\"$port\"}",
        "legendFormat": "{{device}}/{{port}}", "range": false, "refId": "A", "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Up", "color": "green" } } },
            { "type": "range", "options": { "from": 0.000001, "to": 1e15, "result": { "text": "Down", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "none", "noValue": "No IB device"
        }, "overrides": []
      },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto", "textMode": "value_and_name", "colorMode": "value", "graphMode": "none" }
    },
