{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Node Detail", "url": "/d/argus-node-detail?var-node=${__data.fields.instance}", "type": "link" },
    { "title": "Link Drill-Down", "url": "/d/argus-link-drilldown", "type": "link" }
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Nodes Healthy",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "count(argus_health_state{instance=~\"$node\"} == 0) or vector(0)",
        "refId": "A", "instant": true, "range": false
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "none", "noValue": "0"
        }, "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }
    },
    {
      "id": 2, "type": "stat", "title": "Nodes Degraded",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "count(argus_health_state{instance=~\"$node\"} == 1) or vector(0)",
        "refId": "A", "instant": true, "range": false
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "yellow", "mode": "fixed" },
          "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }] },
          "unit": "none", "noValue": "0"
        }, "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }
    },
    {
      "id": 3, "type": "stat", "title": "Nodes Critical",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "count(argus_health_state{instance=~\"$node\"} == 2) or vector(0)",
        "refId": "A", "instant": true, "range": false
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] },
          "unit": "none", "noValue": "0"
        }, "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }
    },
    {
      "id": 4, "type": "gauge", "title": "Worst Health Score",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "max(argus_health_score_millis{instance=~\"$node\"}) / 1000 or vector(0)",
        "refId": "A", "instant": true, "range": false
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "red", "value": 0.7 }
          ]},
          "unit": "none", "noValue": "0"
        }, "overrides": []
      },
      "options": { "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true, "sizing": "auto",
        "minVizHeight": 75, "minVizWidth": 75,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 5, "type": "stat", "title": "Total Alerts (15m)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "sum(increase(argus_alerts_total{instance=~\"$node\"}[15m])) or vector(0)",
        "refId": "A", "instant": true, "range": false
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 10 }
          ]},
          "unit": "none", "noValue": "0"
        }, "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }
    },
    {
      "id": 15, "type": "stat", "title": "Events Processed",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "sum(argus_events_total{instance=~\"$node\"}) or vector(0)",
        "refId": "A", "instant": true, "range": false
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short", "noValue": "0"
        }, "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" }
    },
    {
      "id": 6, "type": "state-timeline", "title": "Node Health State",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_health_state{instance=~\"$node\"}",
        "refId": "A", "legendFormat": "{{instance}}", "range": true
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "axisPlacement": "auto", "fillOpacity": 70, "lineWidth": 0, "spanNulls": false,
            "insertNulls": false,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "mappings": [{ "type": "value", "options": {
            "0": { "color": "green", "index": 0, "text": "Healthy" },
            "1": { "color": "yellow", "index": 1, "text": "Degraded" },
            "2": { "color": "red", "index": 2, "text": "Critical" }
          }}],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 2 }
          ]},
          "unit": "none"
        }, "overrides": []
      },
      "options": { "alignValue": "left", "mergeValues": true, "rowHeight": 0.9, "showValue": "auto",
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 10, "type": "timeseries", "title": "IRQ Affinity Skew %",
      "description": "Percentage of all IRQs handled by the busiest CPU. >70% indicates poor balancing.",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_irq_skew_pct{instance=~\"$node\"}",
        "refId": "A", "legendFormat": "{{instance}}", "range": true
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20,
            "stacking": { "mode": "none" }, "showPoints": "never",
            "thresholdsStyle": { "mode": "line" } },
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 70 }
            ]
          }
        }, "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 11, "type": "timeseries", "title": "Slab Alloc Rate",
      "description": "Kernel slab allocations per window. Spikes correlate with memory pressure.",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "increase(argus_slab_alloc_total{instance=~\"$node\"}[$__rate_interval])",
        "refId": "A", "legendFormat": "{{instance}}", "range": true
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "showPoints": "never",
            "gradientMode": "opacity", "spanNulls": false },
          "unit": "ops"
        }, "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 12, "type": "timeseries", "title": "NAPI Utilization %",
      "description": "NIC polling budget utilization. >90% means the kernel is saturated processing packets.",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_napi_utilization_pct{instance=~\"$node\"}",
        "refId": "A", "legendFormat": "{{instance}}", "range": true
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "showPoints": "never",
            "gradientMode": "opacity", "spanNulls": false,
            "thresholdsStyle": { "mode": "area" } },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }, "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 13, "type": "timeseries", "title": "Health Score Over Time",
      "description": "Composite health score (0=healthy, 1=worst). Combines all detection signals.",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_health_score_millis{instance=~\"$node\"} / 1000",
        "refId": "A", "legendFormat": "{{instance}}", "range": true
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 25, "showPoints": "never",
            "gradientMode": "opacity", "spanNulls": false,
            "thresholdsStyle": { "mode": "area" } },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "red", "value": 0.7 }
          ]},
          "unit": "none", "min": 0, "max": 1
        }, "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 14, "type": "timeseries", "title": "Slab Avg Latency",
      "description": "Average kernel slab allocation latency. Spikes indicate memory subsystem pressure.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_slab_avg_latency_ns{instance=~\"$node\"}",
        "refId": "A", "legendFormat": "{{instance}} avg", "range": true
      },
      {
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_slab_max_latency_ns{instance=~\"$node\"}",
        "refId": "B", "legendFormat": "{{instance}} max", "range": true
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never",
            "gradientMode": "opacity", "spanNulls": false },
          "unit": "ns"
        }, "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 7, "type": "table", "title": "All Nodes",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
          "expr": "argus_health_state{instance=~\"$node\"}", "refId": "A",
          "exemplar": false, "format": "table", "instant": true, "legendFormat": "State", "range": false },
        { "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
          "expr": "argus_health_score_millis{instance=~\"$node\"}", "refId": "B",
          "exemplar": false, "format": "table", "instant": true, "legendFormat": "Score", "range": false },
        { "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
          "expr": "argus_ib_error_delta_total{instance=~\"$node\"}", "refId": "C",
          "exemplar": false, "format": "table", "instant": true, "legendFormat": "IB Errors", "range": false },
        { "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
          "expr": "argus_napi_utilization_pct{instance=~\"$node\"}", "refId": "D",
          "exemplar": false, "format": "table", "instant": true, "legendFormat": "NAPI %", "range": false }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true, "inspect": false },
          "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "State" }, "properties": [
            { "id": "mappings", "value": [{ "type": "value", "options": {
              "0": { "color": "green", "index": 0, "text": "Healthy" },
              "1": { "color": "yellow", "index": 1, "text": "Degraded" },
              "2": { "color": "red", "index": 2, "text": "Critical" }
            }}]},
            { "id": "custom.cellOptions", "value": { "type": "color-background" } }
          ]},
          { "matcher": { "id": "byName", "options": "NAPI %" }, "properties": [
            { "id": "unit", "value": "percent" },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]}},
            { "id": "custom.cellOptions", "value": { "type": "color-background" } }
          ]}
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true, "sortBy": [{ "desc": false, "displayName": "instance" }]
      },
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": {
          "excludeByName": { "Time": true },
          "indexByName": {},
          "renameByName": { "Value #A": "State", "Value #B": "Score", "Value #C": "IB Errors", "Value #D": "NAPI %" }
        }}
      ]
    },
    {
      "id": 8, "type": "table", "title": "Recent Alerts",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "sum by (kind, severity) (increase(argus_alerts_total{instance=~\"$node\"}[5m])) > 0",
        "refId": "A", "exemplar": false, "format": "table", "instant": true, "range": false
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true, "inspect": false },
          "mappings": [], "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }
          ]},
          "unit": "none", "noValue": "No alerts in the last 5 minutes"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "severity" }, "properties": [
            { "id": "mappings", "value": [{ "type": "value", "options": {
              "critical": { "color": "red", "index": 0, "text": "critical" },
              "warning": { "color": "yellow", "index": 1, "text": "warning" },
              "info": { "color": "green", "index": 2, "text": "info" }
            }}]}
          ]}
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true, "sortBy": []
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["argus", "fleet", "overview"],
  "templating": {
    "list": [{
      "allValue": ".*",
      "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "definition": "label_values(argus_health_state, instance)",
      "hide": 0, "includeAll": true, "label": "Node", "multi": true, "name": "node",
      "options": [],
      "query": "label_values(argus_health_state, instance)",
      "refresh": 1, "regex": "", "skipUrlSync": false, "sort": 1, "type": "query"
    }]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ARGUS Fleet Overview",
  "uid": "argus-fleet-overview",
  "version": 2,
  "weekStart": ""
}
