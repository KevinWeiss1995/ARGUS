{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1, "type": "state-timeline", "title": "Health State",
      "gridPos": { "h": 5, "w": 10, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_health_state{instance=\"$node\"}",
        "legendFormat": "state", "range": true, "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 70, "lineWidth": 0, "spanNulls": false },
          "mappings": [{ "type": "value", "options": {
            "0": { "color": "green", "text": "Healthy" },
            "1": { "color": "yellow", "text": "Degraded" },
            "2": { "color": "red", "text": "Critical" }
          }}],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 }
          ]}
        }, "overrides": []
      },
      "options": { "alignValue": "left", "mergeValues": true, "rowHeight": 0.9, "showValue": "auto",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 2, "type": "gauge", "title": "Health Score",
      "gridPos": { "h": 5, "w": 5, "x": 10, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_health_score_millis{instance=\"$node\"} / 1000",
        "legendFormat": "score", "range": false, "refId": "A", "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "none", "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 0.3 }, { "color": "red", "value": 0.7 }
          ]}
        }, "overrides": []
      },
      "options": { "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true,
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" } }
    },
    {
      "id": 3, "type": "stat", "title": "Alerts (15m)",
      "gridPos": { "h": 5, "w": 4, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "sum(increase(argus_alerts_total{instance=\"$node\"}[15m])) or vector(0)",
        "legendFormat": "", "range": false, "refId": "A", "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "red", "value": 1 }
          ]}
        }, "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "textMode": "auto" }
    },
    {
      "id": 16, "type": "stat", "title": "Events Total",
      "gridPos": { "h": 5, "w": 5, "x": 19, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_events_total{instance=\"$node\"} or vector(0)",
        "refId": "A", "instant": true, "range": false
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "unit": "short", "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }, "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "textMode": "auto" }
    },
    {
      "id": 20, "type": "row", "title": "Kernel Probes (eBPF)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "collapsed": false, "panels": []
    },
    {
      "id": 11, "type": "timeseries", "title": "IRQ Skew %",
      "description": "Share of all IRQs handled by the busiest CPU. >70% = affinity problem. Works at any CPU count.",
      "gridPos": { "h": 8, "w": 5, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_irq_skew_pct{instance=\"$node\"}",
        "legendFormat": "skew %", "range": true, "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20,
            "showPoints": "never", "thresholdsStyle": { "mode": "area" } },
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 70 }
          ]}
        }, "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 21, "type": "stat", "title": "Dominant CPU",
      "description": "Which CPU is handling the most IRQs right now.",
      "gridPos": { "h": 4, "w": 3, "x": 5, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_irq_dominant_cpu{instance=\"$node\"}",
        "legendFormat": "", "range": false, "refId": "A", "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "text", "mode": "fixed" },
          "unit": "none", "noValue": "N/A"
        }, "overrides": []
      },
      "options": { "colorMode": "none", "graphMode": "none", "justifyMode": "center", "orientation": "auto",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "textMode": "value" }
    },
    {
      "id": 22, "type": "stat", "title": "IRQ Rate (all CPUs)",
      "description": "Total IRQs across all CPUs in the current window.",
      "gridPos": { "h": 4, "w": 3, "x": 5, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_irq_total_rate{instance=\"$node\"}",
        "legendFormat": "", "range": false, "refId": "A", "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "unit": "short", "noValue": "0"
        }, "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "textMode": "auto" }
    },
    {
      "id": 12, "type": "timeseries", "title": "Slab Alloc Rate",
      "description": "Kernel slab cache allocations per window.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "increase(argus_slab_alloc_total{instance=\"$node\"}[$__rate_interval])",
        "legendFormat": "alloc/window", "range": true, "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "showPoints": "never",
            "gradientMode": "opacity" },
          "unit": "ops"
        }, "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 13, "type": "timeseries", "title": "NAPI Utilization %",
      "description": "NIC poll budget utilization. >90% = packet processing saturation.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_napi_utilization_pct{instance=\"$node\"}",
        "legendFormat": "napi %", "range": true, "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "showPoints": "never",
            "gradientMode": "opacity", "thresholdsStyle": { "mode": "area" } },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }, "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 14, "type": "timeseries", "title": "Slab Latency (ns)",
      "description": "Slab allocation latency: average and per-window max.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
          "expr": "argus_slab_avg_latency_ns{instance=\"$node\"}", "legendFormat": "avg", "range": true, "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
          "expr": "argus_slab_max_latency_ns{instance=\"$node\"}", "legendFormat": "max", "range": true, "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never",
            "gradientMode": "opacity" },
          "unit": "ns"
        }, "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 15, "type": "timeseries", "title": "Health Score Over Time",
      "description": "Composite health score: 0 = perfectly healthy, 1 = worst.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_health_score_millis{instance=\"$node\"} / 1000",
        "legendFormat": "score", "range": true, "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 25, "showPoints": "never",
            "gradientMode": "opacity", "thresholdsStyle": { "mode": "area" } },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 0.3 }, { "color": "red", "value": 0.7 }
          ]},
          "unit": "none", "min": 0, "max": 1
        }, "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 30, "type": "row", "title": "CQ Jitter (RDMA Completion Queue)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }, "collapsed": false, "panels": []
    },
    {
      "id": 8, "type": "timeseries", "title": "CQ Avg Latency (ns)",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_cq_avg_latency_ns{instance=\"$node\"}",
        "legendFormat": "avg", "range": true, "refId": "A"
      }],
      "fieldConfig": { "defaults": {
        "color": { "mode": "palette-classic" },
        "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
        "unit": "ns", "noValue": "No CQ data (no RDMA device)"
      }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 9, "type": "timeseries", "title": "CQ Max Latency (ns)",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "argus_cq_max_latency_ns{instance=\"$node\"}",
        "legendFormat": "max", "range": true, "refId": "A"
      }],
      "fieldConfig": { "defaults": {
        "color": { "mode": "palette-classic" },
        "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
        "unit": "ns", "noValue": "No CQ data (no RDMA device)"
      }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 10, "type": "timeseries", "title": "CQ Stalls",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "editorMode": "code",
        "expr": "increase(argus_cq_stalls_total{instance=\"$node\"}[5m])",
        "legendFormat": "stalls/5m", "range": true, "refId": "A"
      }],
      "fieldConfig": { "defaults": {
        "color": { "mode": "palette-classic" },
        "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
        "unit": "short", "noValue": "No CQ data (no RDMA device)"
      }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 40, "type": "row", "title": "InfiniBand Hardware Counters",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 }, "collapsed": true,
      "panels": [
        {
          "id": 4, "type": "timeseries", "title": "IB Errors",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "targets": [
            { "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
              "expr": "argus_ib_symbol_errors_delta{instance=\"$node\",device=~\"$device\",port=~\"$port\"}", "legendFormat": "symbol_errors", "range": true, "refId": "A" },
            { "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
              "expr": "argus_ib_link_error_recovery_delta{instance=\"$node\",device=~\"$device\",port=~\"$port\"}", "legendFormat": "link_error_recovery", "range": true, "refId": "B" },
            { "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
              "expr": "argus_ib_link_downed_delta{instance=\"$node\",device=~\"$device\",port=~\"$port\"}", "legendFormat": "link_downed", "range": true, "refId": "C" },
            { "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
              "expr": "argus_ib_port_rcv_errors_delta{instance=\"$node\",device=~\"$device\",port=~\"$port\"}", "legendFormat": "port_rcv_errors", "range": true, "refId": "D" }
          ],
          "fieldConfig": { "defaults": {
            "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 35, "showPoints": "never",
              "stacking": { "mode": "normal", "group": "A" } },
            "unit": "short", "noValue": "No IB hardware detected"
          }, "overrides": [] },
          "options": {
            "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
            "tooltip": { "mode": "multi", "sort": "desc" } }
        },
        {
          "id": 5, "type": "timeseries", "title": "Port Xmit Wait (Congestion)",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "targets": [{
            "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
            "expr": "argus_ib_port_xmit_wait_delta{instance=\"$node\",device=~\"$device\",port=~\"$port\"}", "legendFormat": "{{device}}/{{port}}", "range": true, "refId": "A"
          }],
          "fieldConfig": { "defaults": {
            "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
            "unit": "short", "noValue": "No IB hardware detected"
          }, "overrides": [] },
          "options": {
            "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
            "tooltip": { "mode": "single", "sort": "none" } }
        },
        {
          "id": 6, "type": "timeseries", "title": "Throughput Bytes/window",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "targets": [{
            "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
            "expr": "argus_ib_throughput_rcv_bytes{instance=\"$node\",device=~\"$device\",port=~\"$port\"} + argus_ib_throughput_xmit_bytes{instance=\"$node\",device=~\"$device\",port=~\"$port\"}",
            "legendFormat": "rcv+xmit bytes", "range": true, "refId": "A"
          }],
          "fieldConfig": { "defaults": {
            "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
            "unit": "bytes", "noValue": "No IB hardware detected"
          }, "overrides": [] },
          "options": {
            "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
            "tooltip": { "mode": "multi", "sort": "desc" } }
        },
        {
          "id": 7, "type": "timeseries", "title": "Throughput Pkts/window",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "targets": [{
            "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" }, "editorMode": "code",
            "expr": "argus_ib_throughput_rcv_pkts{instance=\"$node\",device=~\"$device\",port=~\"$port\"} + argus_ib_throughput_xmit_pkts{instance=\"$node\",device=~\"$device\",port=~\"$port\"}",
            "legendFormat": "rcv+xmit pkts", "range": true, "refId": "A"
          }],
          "fieldConfig": { "defaults": {
            "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
            "unit": "short", "noValue": "No IB hardware detected"
          }, "overrides": [] },
          "options": {
            "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
            "tooltip": { "mode": "multi", "sort": "desc" } }
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["argus", "node", "detail"],
  "templating": {
    "list": [
      { "current": {}, "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "definition": "label_values(argus_health_state, instance)",
        "hide": 0, "includeAll": false, "multi": false, "name": "node", "label": "node",
        "options": [], "query": "label_values(argus_health_state, instance)",
        "refresh": 1, "regex": "", "skipUrlSync": false, "sort": 1, "type": "query" },
      { "current": {}, "allValue": ".*", "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "definition": "label_values(argus_ib_symbol_errors_delta{instance=\"$node\"}, device)",
        "hide": 0, "includeAll": true, "multi": true, "name": "device", "label": "device",
        "options": [], "query": "label_values(argus_ib_symbol_errors_delta{instance=\"$node\"}, device)",
        "refresh": 1, "regex": "", "skipUrlSync": false, "sort": 1, "type": "query" },
      { "current": {}, "allValue": ".*", "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "definition": "label_values(argus_ib_symbol_errors_delta{instance=\"$node\", device=~\"$device\"}, port)",
        "hide": 0, "includeAll": true, "multi": true, "name": "port", "label": "port",
        "options": [], "query": "label_values(argus_ib_symbol_errors_delta{instance=\"$node\", device=~\"$device\"}, port)",
        "refresh": 1, "regex": "", "skipUrlSync": false, "sort": 1, "type": "query" }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "ARGUS Node Detail",
  "uid": "argus-node-detail",
  "version": 2,
  "weekStart": "",
  "id": null
}
